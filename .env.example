# API
API_HOST=0.0.0.0
API_PORT=8000
CORS_ORIGINS=*

# Database (SQLite file — created automatically on startup)
# DATABASE_PATH is optional; default: ./data/db/trialon.db

# Rate limit: 10 try-ons per hour per IP (no login)
TRYON_RATE_LIMIT=10
TRYON_RATE_WINDOW_HOURS=1

# Storage (relative paths work on Linux VM and Windows dev)
UPLOAD_DIR=./data/uploads
OUTPUT_DIR=./data/outputs
MODEL_CACHE_DIR=./models

# ML settings
DEVICE=cuda
TORCH_DTYPE=float16
INFERENCE_STEPS=50
GUIDANCE_SCALE=3.0
OUTPUT_WIDTH=768
OUTPUT_HEIGHT=1024
MASK_BLUR_FACTOR=5
CLOTH_TYPE=upper
INFERENCE_SEED=42

# HUBA 7-stage pipeline (noisy phone photos — streetwear)
ENABLE_HUBA_PIPELINE=true
ENABLE_PIPELINE_STAGE0=true
ENABLE_PIPELINE_STAGE2=true
ENABLE_PIPELINE_STAGE4=true
ENABLE_PIPELINE_STAGE5=true
ENABLE_PIPELINE_STAGE6=true
PIPELINE_DEBUG=false
PIPELINE_MIN_SHORT_EDGE=512
PIPELINE_BLUR_THRESHOLD=80
PIPELINE_PARSE_CONFIDENCE=0.45
PIPELINE_PRE_UPSCALE=true
PIPELINE_AUTO_WHITE_BALANCE=true
PIPELINE_UPSCALE_FACTOR=1.0
# Optional heavy models (install requirements-pipeline.txt + download weights)
ENABLE_BIREFNET=false
ENABLE_GFPGAN=false
ENABLE_REALESRGAN=false

# Model identifiers (HuggingFace)
CATVTON_MODEL_ID=zhengchong/CatVTON
CATVTON_BASE_MODEL_ID=runwayml/stable-diffusion-inpainting
CATVTON_ATTN_VERSION=mix

# Monitoring
SENTRY_DSN=
ENABLE_PROMETHEUS=true
LOG_LEVEL=INFO
